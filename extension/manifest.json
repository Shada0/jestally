{
  "manifest_version": 3,
  "name": "Jestally — Indian Sign Language",
  "short_name": "Jestally",
  "version": "3.1.0",
  "description": "Real-time Indian Sign Language translation and recognition — works on every website.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["panel.css"],
    "run_at": "document_idle",
    "all_frames": false
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jestally ISL",
    "default_icon": { "16":"icons/icon16.png","32":"icons/icon32.png","48":"icons/icon48.png","128":"icons/icon128.png" }
  },
  "icons": { "16":"icons/icon16.png","32":"icons/icon32.png","48":"icons/icon48.png","128":"icons/icon128.png" },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [{
    "resources": ["panel.css","icons/*"],
    "matches": ["<all_urls>"]
  }]
}
